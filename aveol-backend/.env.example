# ============================================================
# AVEOL BACKEND — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=https://aveol.netlify.app

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/aveol_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_this
JWT_EXPIRES_IN=7d

# Nodemailer (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@aveol.ai
SMTP_PASS=your_gmail_app_password
EMAIL_FROM_NAME=AVEOL AI Automation
EMAIL_FROM_ADDRESS=hello@aveol.ai
ADMIN_EMAIL=admin@aveol.ai

# Calendly Webhook
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_signing_secret
CALENDLY_API_TOKEN=your_calendly_personal_access_token
CALENDLY_BOOKING_URL=https://calendly.com/aveol/strategy-call

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin
ADMIN_REGISTRATION_CODE=AVEOL_ADMIN_2026
